@model MeaxHub.Models.Home.HomeViewModel

@{
    ViewData["Title"] = "MEAX Hub";
}

<div class="row mb-4">
    <div class="col">
        <h3 class="mb-0">Sistemas MEAX</h3>
        <p class="text-muted mb-0">Selecciona el sistema al que deseas acceder.</p>
    </div>
</div>

<div class="row">
    @foreach (var s in Model.Systems)
    {
        <div class="col-md-4 col-lg-3 mb-3">
            <a href="@s.Url" class="text-decoration-none" target="_blank" rel="noopener">
                <div class="card shadow-sm h-100 hover-raise">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1">@s.Name</h5>
                        <p class="card-subtitle text-muted small mb-2">@s.Code</p>
                        <p class="mt-auto small text-primary">
                            Ir al sistema <i class="fas fa-arrow-right ms-1"></i>
                        </p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>
