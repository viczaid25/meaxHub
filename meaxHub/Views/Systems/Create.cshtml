@model MeaxHub.Models.Systems.SystemCreateViewModel

@{
    ViewData["Title"] = "Alta de sistemas";
    Layout = "_Layout"; // Usa el layout del Hub
}

<div class="row mb-3">
    <div class="col">
        <h3 class="mb-0">
            <i class="fas fa-server me-2"></i>Alta de sistemas
        </h3>
        <p class="text-muted mb-0">
            Registra sistemas para que aparezcan en el menú del MEAX Hub.
        </p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center">
        <i class="fas fa-check-circle me-2"></i>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" asp-controller="Systems" method="post" class="row g-3">
            @Html.AntiForgeryToken()

            <div class="col-md-3">
                <div class="form-floating">
                    <input asp-for="Code" class="form-control" />
                    <label asp-for="Code"></label>
                </div>
                <span asp-validation-for="Code" class="text-danger small"></span>
            </div>

            <div class="col-md-5">
                <div class="form-floating">
                    <input asp-for="Name" class="form-control" />
                    <label asp-for="Name"></label>
                </div>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <div class="form-floating">
                    <input asp-for="Url" class="form-control" />
                    <label asp-for="Url"></label>
                </div>
                <span asp-validation-for="Url" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex align-items-center">
                <div class="form-check form-switch">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>
            </div>

            <div class="col-12 mt-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i> Guardar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
